{
    "name": "aybarsm/laravel-extra",
    "version": "dev-main",
    "description": "An opinionated Laravel extra provider library.",
    "type": "library",
    "license": "MIT",
    "keywords": ["aybarsm", "php", "laravel", "extra", "support"],
    "homepage": "https://www.github.com/aybarsm/laravel-extra",
    "support": {
        "email": "dev@blrm.net"
    },
    "authors": [
        {
            "name": "Murat Aybars",
            "email": "murat.aybars@blrm.net",
            "homepage": "https://www.blrm.net",
            "role": "Founder"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.0",
        "spatie/laravel-package-tools": "^1.0",
        "spatie/laravel-data": "^4.0",
        "aybarsm/php-extra": "dev-main"
    },
    "require-dev": {
        "pestphp/pest": "^4.4"
    },
    "autoload": {
        "psr-4": {
            "Aybarsm\\Laravel\\Extra\\": "src"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aybarsm\\Laravel\\Extra\\LaravelExtraServiceProvider"
            ],
            "aliases": {
                "LaravelExtra": "Aybarsm\\Laravel\\Extra\\Facades\\LaravelExtra"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
