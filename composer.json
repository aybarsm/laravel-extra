{
    "name": "aybarsm/laravel-extra",
    "version": "dev-main",
    "description": "An opinionated Laravel extra provider library.",
    "type": "library",
    "license": "MIT",
    "keywords": ["aybarsm", "php", "laravel", "extra", "support"],
    "homepage": "https://www.github.com/aybarsm/laravel-extra",
    "support": {
        "email": "dev@blrm.net"
    },
    "authors": [
        {
            "name": "Murat Aybars",
            "email": "murat.aybars@blrm.net",
            "homepage": "https://www.blrm.net",
            "role": "Founder"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "pestphp/pest": "^4.4"
    },
    "autoload": {
        "psr-4": {
            "Aybarsm\\Laravel\\Extra\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aybarsm\\Laravel\\Extra\\ExtraServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
